# Copy this file to .env on the server at:
#   /var/www/football-simulation/.env
# Keep it OUTSIDE the dist/ webroot so it is never publicly accessible.
# Do NOT commit the real .env (the repo .gitignore already excludes it).

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=football_sessions
DB_USERNAME=football_user
DB_PASSWORD=replace_me_with_the_real_password
